# Dev: leave VITE_API_URL unset or empty so the Vite dev server proxies /api and /oauth2 to the API.
# Google OAuth authorized redirect URI must be: http://localhost:5173/login/oauth2/code/google
# (add http://127.0.0.1:5173/login/oauth2/code/google if you open the app via 127.0.0.1)
VITE_DEV_PROXY_TARGET=http://localhost:8080
